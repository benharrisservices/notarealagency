# PostgreSQL connection string (local, Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nara?schema=public"

# 32+ char secret used to sign admin session JWTs (openssl rand -base64 48)
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Public site URL, used for canonical URLs, sitemap and Open Graph
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Seed admin credentials (created by `npm run db:seed`)
ADMIN_EMAIL="admin@nara.london"
ADMIN_PASSWORD="nara-admin"

# Optional: improves "Import Listing" PDF field extraction.
# If unset, import falls back to built-in heuristic extraction.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"
