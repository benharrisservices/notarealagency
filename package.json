{
  "name": "nara-real-estate",
  "version": "1.0.0",
  "private": true,
  "description": "NARA — a production property-opportunities platform (Next.js 15, Prisma, PostgreSQL).",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:seed:fresh": "SEED_RESET=true prisma db seed",
    "db:verify": "tsx prisma/verify.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
